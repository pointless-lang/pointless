fn permutations(elems)
  if elems == [] then 
    [[]]
  else
    elems
      $ subPermute(elems)
      | List.merge
  end
end

fn permutations(elems)
  elems == []
    then [[]]
    else (elems $ subPermute(elems) | List.merge)
end

