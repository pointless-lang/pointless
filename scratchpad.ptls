fn showRow(row)
  row
    $ if arg == 0 then " " else arg end
    | List.chunks(3)
    $ join(" ")
    | join(" | ")
end

fn showRow(row)
  row
    $ arg == 0 then " " else arg
    | List.chunks(3)
    $ join(" ")
    | join(" | ")
end

