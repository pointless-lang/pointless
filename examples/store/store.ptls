Csv = import "std:Csv"

customers = Csv.read(asset "data/customers.csv")
invoices = Csv.read(asset "data/invoices.csv")

invoices
  | Table.join(customers, "customerId")
  | select(["firstName", "lastName", "total", "country"])
  | Table.summarize("country", Table.average)
  | sortDescBy("total")
  | roundTo(2)
  | print
