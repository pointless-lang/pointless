coins = #{
  name      , value , count
  "dollar"  ,   100 ,     0
  "quarter" ,    25 ,     0
  "dime"    ,    10 ,     0
  "nickle"  ,     5 ,     0
  "penny"   ,     1 ,     0
}

fn calcChange(cents)
  for coin in coins do
    count = cents // coin.value
    coins[coin].count = count
    cents -= count * coin.value
  end

  coins
end

print(calcChange(468))
