Csv = import "std:Csv"

cities = Csv.read(asset "cities.csv")

cities #= {
  pctChange: arg.pop2024 / arg.pop2020 * 100 - 100,
  popChange: arg.pop2024 - arg.pop2020,
  density: arg.pop2024 / arg.area,
}

cities |= roundTo(1)
cities |= remove(["pop2020", "area"])

cities
  | Table.top("pctChange", 10)
  | print
